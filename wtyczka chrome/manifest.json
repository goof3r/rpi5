{
  "manifest_version": 3,
  "name": "Transmission Notifier",
  "version": "1.0.0",
  "description": "Powiadomienia o pobranych torrentach z wielu serwerow Transmission. Dodawanie magnetlinkow i plikow .torrent.",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "contextMenus"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Transmission Notifier",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
