# Skopiuj ten plik jako .env i uzupełnij wartości

# Klucz sesji Flask (zmień na długi losowy ciąg znaków!)
SECRET_KEY=zmien-mnie-na-losowy-dlugi-ciag

# Połączenie z MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=proxmox_manager
DB_USER=proxmox_user
DB_PASSWORD=silne_haslo_mysql

# Port na którym uruchomi się aplikacja
FLASK_PORT=5000
FLASK_DEBUG=false
