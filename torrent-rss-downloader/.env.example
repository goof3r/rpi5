# Wygeneruj losowy klucz: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Katalog danych — baza SQLite torrents.db (domyślnie /var/lib/torrent-rss)
# DATA_DIR=/var/lib/torrent-rss

# URL kanału RSS (wymagane)
RSS_FEED_URL=https://adres_trakera.pl/rss/TWOJ_TOKEN.xml

# Interwał odpytywania RSS w minutach (domyślnie 15)
RSS_POLL_INTERVAL=15

# Ustawienia serwera Flask
FLASK_PORT=5000
FLASK_DEBUG=false

# Ustaw false na workerach gunicorn, które NIE mają uruchamiać schedulera
SCHEDULER_ENABLED=true
